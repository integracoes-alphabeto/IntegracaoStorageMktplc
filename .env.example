PORT=3000

# Protecao da interface quando hospedado
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=

# Bucket alvo
GCS_BUCKET_NAME=mktplacealpha
GCS_PROJECT_ID=flowing-flame-322416

# Escolha UMA forma de autenticacao.
# Para hospedagem, prefira GCS_SERVICE_ACCOUNT_JSON_BASE64 em vez de subir arquivo em secrets/.
GCS_CREDENTIALS_FILE=./secrets/flowing-flame-322416-c1664e4db53e.json
GCS_SERVICE_ACCOUNT_JSON=
GCS_SERVICE_ACCOUNT_JSON_BASE64=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY_BASE64_PART1=
GCS_PRIVATE_KEY_BASE64_PART2=
GCS_PRIVATE_KEY_BASE64_PART3=
GCS_PRIVATE_KEY_BASE64_PART4=
GCS_TOKEN_URI=https://oauth2.googleapis.com/token

# Geracao de link
GCS_URL_MODE=public
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/mktplacealpha
GCS_MAKE_PUBLIC=false
GCS_SIGNED_URL_DAYS=7

# Organizacao
GCS_DEFAULT_PREFIX=produtos
MAX_FILES_PER_UPLOAD=10000
MAX_FILE_SIZE_MB=20

# Busca de fotos na VTEX por SKU
VTEX_ACCOUNT_NAME=alphabeto
VTEX_API_BASE_URL=https://alphabeto.vtexcommercestable.com.br
VTEX_API_APP_KEY=
VTEX_API_APP_TOKEN=
VTEX_MAX_EXPORT_SKUS=2500
VTEX_REQUEST_CONCURRENCY=6
